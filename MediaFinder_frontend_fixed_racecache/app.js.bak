function dtwBand(a,b,w=10){
  const n=a.length, m=b.length;
  const W = Math.max(w, Math.abs(n-m));
  const INF = 1e9;
  const D = Array.from({length:n+1}, ()=> new Float64Array(m+1).fill(INF));
  D[0][0]=0;
  for(let i=1;i<=n;i++){
    const jStart = Math.max(1, i-W);
    const jEnd   = Math.min(m, i+W);
    for(let j=jStart;j<=jEnd;j++){
      const cost = 1 - Math.min(1, Math.max(0, (a[i-1]+b[j-1])/2 ));
      const d = cost + Math.min(D[i-1][j], D[i][j-1], D[i-1][j-1]);
      D[i][j] = d;
    }
  }
  // backtrack
  let i=n, j=m; const path=[];
  while(i>0 && j>0){
    path.push([i-1,j-1]);
    const d = D[i][j] - (1 - Math.min(1, Math.max(0, (a[i-1]+b[j-1])/2 )));
    if(D[i-1][j-1] <= D[i-1][j] && D[i-1][j-1] <= D[i][j-1]){ i--; j--; }
    else if(D[i-1][j] < D[i][j-1]){ i--; }
    else { j--; }
  }
  path.reverse();
  const normCost = D[n][m]/path.length;
  return {cost: D[n][m], normCost, path};
}
document.getElementById('runDTW')?.addEventListener('click', ()=>{
  if(!window.__lastAnalysis){ alert('Lakukan analisis dahulu.'); return; }
  const a = window.__lastAnalysis.fused;
  const b = window.__lastVis || a; // fallback
  const w = Number(document.getElementById('dtwBand').value)||10;
  const res = dtwBand(a,b,w);
  const sim = 1 - Math.min(1, Math.max(0, res.normCost)); // approx sim
  document.getElementById('dtwInfo').textContent = `DTW-Lite: path=${res.path.length}, skorâ‰ˆ${sim.toFixed(3)}`;
  // plot mapping i->j
  const map = new Array(res.path.length).fill(0).map((_,k)=>res.path[k][1]-res.path[k][0]);
  plotLine(document.getElementById('dtwPlot'), map, '#2e7d32');
});


document.getElementById('exportPdf')?.addEventListener('click', async ()=>{
  try{
    if(isLocalOnly()){ alert('Mode Local-only aktif. Export PDF dinonaktifkan.'); return; }
    if(!window.jspdf || !window.jspdf.jsPDF){ alert('jsPDF belum termuat (butuh internet).'); return; }
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({unit:'pt', format:'a4'});
    const title = document.title || 'MediaFinder Report';
    doc.setFontSize(14); doc.text(title, 40, 40);
    const A = window.__lastAnalysis;
    if(A){
      const global = (A.fused.reduce((x,y)=>x+y,0)/(A.fused.length||1)).toFixed(3);
      doc.setFontSize(11); doc.text(`Global score: ${global} (wv=${A.wv}, wa=${A.wa})`, 40, 60);
    }
    const canv1 = document.getElementById('timeline');
    const canv2 = document.getElementById('heatmap');
    const canv3 = document.getElementById('alignPlot');
    const addImg = (c, x, y, w)=>{ if(!c) return; const data = c.toDataURL('image/png'); const h = c.height*(w/c.width); doc.addImage(data,'PNG',x,y,w,h); return y+h; };
    let y = 80;
    y = addImg(canv1, 40, y, 520) + 20 || y;
    y = addImg(canv2, 40, y, 520) + 20 || y;
    y = addImg(canv3, 40, y, 520) + 20 || y;
    try{
      const shots = window.__shots || [];
      const peaks = window.__topPeaks || [];
      if(peaks.length){ doc.setFontSize(12); doc.text('Top-N Segmen:', 40, y); y += 14; const maxRows=Math.min(10,peaks.length); for(let k=0;k<maxRows;k++){ const p=peaks[k]; doc.text(`${k+1}. t=${p.t}s | score=${p.s.toFixed(3)}`, 48, y); y+=14;} y+=8; }
      if(shots.length){ doc.setFontSize(12); doc.text('Snapshot:', 40, y); y+=10; const maxImg=Math.min(6, shots.length); const colW=260, gap=20; let col=0; for(let k=0;k<maxImg;k++){ const s=shots[k]; const x=40 + col*(colW+gap); let yy=y; try{ doc.addImage(s.query,'JPEG',x,yy,colW,colW*0.56); yy+=colW*0.56+6; }catch(_){}
        if(s.target){ try{ doc.addImage(s.target,'JPEG',x,yy,colW,colW*0.56); yy+=colW*0.56+6; }catch(_){} }
        doc.text(`t=${s.t}s | ${s.score.toFixed(2)}`, x, yy+10);
        col = 1-col; if(col===0){ y = yy + 18; }
        if(y>760 && k<maxImg-1){ doc.addPage(); y=60; }
      } }
    }catch(e){ /* ignore embed issues */ }
    doc.save('mediafinder_report.pdf');
  }catch(e){ alert('Gagal export PDF: '+(e?.message||e)); }
});


function topNPeaks(arr, N=5, minSep=3){
  const peaks = [];
  for(let i=1;i<arr.length-1;i++){
    if(arr[i]>=arr[i-1] && arr[i]>=arr[i+1]) peaks.push({t:i, s:arr[i]});
  }
  peaks.sort((a,b)=> b.s-a.s);
  const chosen=[];
  for(const p of peaks){
    if(chosen.every(q=> Math.abs(q.t - p.t) >= minSep )){
      chosen.push(p);
      if(chosen.length>=N) break;
    }
  }
  return chosen.sort((a,b)=> a.t-b.t);
}

function renderTopTable(list){
  const tb = document.querySelector('#topTable tbody'); if(!tb) return;
  tb.innerHTML='';
  list.forEach((p,i)=>{
    const tr = document.createElement('tr');
    tr.innerHTML = `<td>${i+1}</td><td>${p.t}</td><td>${p.s.toFixed(3)}</td>
      <td><button data-jump="${p.t}">Jump</button></td>`;
    tb.appendChild(tr);
  });
  tb.querySelectorAll('button[data-jump]').forEach(btn=>{
    btn.addEventListener('click', (ev)=>{
      const t = Number(ev.currentTarget.getAttribute('data-jump'));
      playerQ.currentTime = t;
      playerQ.play();
    });
  });
}

document.getElementById('calcTop')?.addEventListener('click', ()=>{
